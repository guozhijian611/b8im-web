# 公开发现服务地址。仅用于 appInfo，不会接收登录 token、cookie 或 App-Id。
VITE_DISCOVERY_BASE_URL=http://127.0.0.1:8888

# domain：使用 mode=domain&domain=<当前 host>；enterprise_code：使用 enterprise_code=<企业码>。
VITE_APP_MODE=domain
VITE_APP_INFO_PATH=/saimulti/appInfo

# 发现完成前的产品壳品牌，不代表任何租户，也不能用于业务请求。
VITE_WEB_DEFAULT_NAME=b8im
VITE_WEB_DEFAULT_LOGO_TEXT=b8
VITE_WEB_DEFAULT_COPYRIGHT=Copyright © 2026 b8im
